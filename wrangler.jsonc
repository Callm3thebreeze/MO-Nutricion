{
	"$schema": "./node_modules/wrangler/config-schema.json",
	"name": "mo-nutricion",
	"compatibility_date": "2026-05-27",
	"compatibility_flags": ["nodejs_compat"],
	"observability": {
		"enabled": true
	},
	"kv_namespaces": [
		{
			"binding": "SESSION"
		}
	],
	"d1_databases": [
		{
			"binding": "EMDASH_DB",
			"database_name": "mara-olivares-nutricio-emdash"
		}
	],
	"r2_buckets": [
		{
			"binding": "EMDASH_MEDIA"
		}
	]
}