{
	"$schema": "./node_modules/wrangler/config-schema.json",
	"name": "mara-olivares-nutricio",
	"compatibility_date": "2026-05-27",
	"compatibility_flags": ["nodejs_compat"],
	"observability": {
		"enabled": true
	},
	"vars": {
		"CONTACT_TO_EMAIL": "hola@maraolivares.com",
		"CONTACT_FROM_EMAIL": "Mara Olivares Nutrició <contacto@maraolivaresnutricio.com>"
	},
	"secrets": {
		"required": ["RESEND_API_KEY"]
	},
	"kv_namespaces": [
		{
			"binding": "SESSION"
		}
	],
	"d1_databases": [
		{
			"binding": "EMDASH_DB",
			"database_name": "mara-olivares-nutricio-emdash"
		}
	],
	"r2_buckets": [
		{
			"binding": "EMDASH_MEDIA"
		}
	]
}
