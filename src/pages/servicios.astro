---
import WaveDivider from "../components/ui/WaveDivider.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/components/services.css";

const services: Array<{
  id: string;
  title: string;
  intro: string;
  focus: string;
  approach: string;
  outcomes: string[];
}> = [
  {
    id: "nutricion-clinica",
    title: "Nutrición clínica",
    intro:
      "Cuando hay síntomas, diagnósticos o tratamientos médicos, la alimentación necesita estructura y calma.",
    focus:
      "Trabajo contigo para priorizar lo importante, reducir ruido y construir una pauta segura que puedas mantener en tu día a día.",
    approach:
      "Empezamos con valoración de historia clínica y hábitos, y aterrizamos una estrategia por fases para que avances sin sentirte desbordada.",
    outcomes: [
      "Plan personalizado y realista",
      "Guía clara para decisiones diarias",
      "Seguimiento y ajustes según evolución",
    ],
  },
  {
    id: "salud-digestiva",
    title: "Salud digestiva",
    intro:
      "Inflamación, hinchazón o malestar digestivo suelen afectar energía, descanso y bienestar emocional.",
    focus:
      "Analizamos síntomas, contexto y tolerancias para detectar detonantes y mejorar tu digestión de forma progresiva.",
    approach:
      "Aplicamos una metodología ordenada: simplificar, observar respuesta del cuerpo y reintroducir con criterio.",
    outcomes: [
      "Menos molestias tras las comidas",
      "Mejor regularidad digestiva",
      "Relación más tranquila con la comida",
    ],
  },
  {
    id: "educacion-nutricional",
    title: "Educación nutricional",
    intro:
      "No se trata de memorizar reglas, sino de aprender a elegir con seguridad en cualquier situación.",
    focus:
      "Transformamos información compleja en decisiones prácticas para que ganes autonomía y constancia.",
    approach:
      "Sesiones centradas en herramientas simples: organización de menús, lectura de etiquetas y adaptaciones reales a tu rutina.",
    outcomes: [
      "Más claridad al planificar tus comidas",
      "Menos dependencia de dietas estrictas",
      "Hábitos sostenibles a largo plazo",
    ],
  },
  {
    id: "salud-hormonal",
    title: "Salud hormonal",
    intro:
      "Las etapas hormonales requieren una nutrición que acompañe tus cambios de energía, apetito y descanso.",
    focus:
      "Adaptamos la estrategia nutricional a tu momento vital para mejorar síntomas y recuperar sensación de equilibrio.",
    approach:
      "Combinamos pautas alimentarias, ritmo de comidas y ajustes de estilo de vida con seguimiento cercano.",
    outcomes: [
      "Más estabilidad energética",
      "Mejor gestión del apetito y saciedad",
      "Rutina alineada con tus necesidades hormonales",
    ],
  },
];
---

<BaseLayout
  title="Servicios"
  description="Conoce en detalle los servicios de Mara Olivares: nutricion clinica, salud digestiva, educacion nutricional y salud hormonal."
  canonicalPath="/servicios"
>
  <section class="section services-hero">
    <div class="container services-hero__inner">
      <div class="services-hero__copy scroll-reveal">
        <h1>Nutrición adaptada a lo que necesitas ahora</h1>
        <WaveDivider />
        <p>
          El objetivo es que salgas de la consulta con claridad, prioridades y
          una ruta realista para cuidar tu digestión, tu energía y tus hábitos.
        </p>
        <nav class="services-hero__index" aria-label="Índice de servicios">
          {
            services.map((service) => (
              <a href={`#${service.id}`}>{service.title}</a>
            ))
          }
        </nav>
      </div>

      <aside
        class="services-hero__panel scroll-reveal"
        style="--home-reveal-delay: 90ms"
      >
        <h2>Una ruta con prioridades claras</h2>
        <p>
          Primero entendemos tu contexto. Después convertimos esa información en
          pasos concretos, medibles y sostenibles.
        </p>
      </aside>
    </div>
  </section>

  <section class="services-flow" aria-label="Bloques de servicios">
    {
      services.map((service, index) => (
        <article
          id={service.id}
          class={`service-block ${index % 2 === 0 ? "service-block--blue" : "service-block--lilac"}`}
        >
          <div class="container service-block__inner">
            <div class="service-block__sticky scroll-reveal">
              <h2>{service.title}</h2>
              <WaveDivider class="service-block__divider" />
              <p>{service.intro}</p>
            </div>

            <div
              class="service-block__content scroll-reveal"
              style="--home-reveal-delay: 90ms"
            >
              <div class="service-block__panel">
                <h3>En qué nos enfocamos</h3>
                <p>{service.focus}</p>
              </div>

              <div class="service-block__panel">
                <h3>Cómo trabajaremos</h3>
                <p>{service.approach}</p>
              </div>

              <div class="service-block__panel service-block__panel--outcomes">
                <h3>Qué puedes esperar</h3>
                <ul class="service-block__outcomes">
                  {service.outcomes.map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        </article>
      ))
    }
  </section>

  <section class="section services-cta">
    <div class="container services-cta__inner scroll-reveal">
      <div>
        <h2>Cuéntame qué te está pasando y vemos por dónde empezar.</h2>
      </div>
      <a class="button" href="/contacto">Solicitar valoración</a>
    </div>
  </section>
</BaseLayout>
