---
import { PortableText } from 'astro-portabletext';

import BlogMeta from '../../components/blog/BlogMeta.astro';
import { getPostBySlug } from '../../lib/emdash';
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/components/blog.css';

const slug = Astro.params.slug?.trim() ?? '';
const post = slug.length > 0 ? await getPostBySlug(slug) : null;

if (!post) {
	Astro.response.status = 404;
}

const postPath = post ? `/blog/${post.slug}` : '/blog';
---

<BaseLayout
	title={post ? post.seoTitle ?? post.title : 'Artículo no encontrado'}
	description={
		post
			? post.seoDescription ?? post.excerpt
			: 'El artículo que buscas no está disponible o ya no está publicado.'
	}
	canonicalPath={postPath}
	canonicalUrl={post?.canonicalUrl}
	type={post ? 'article' : 'website'}
	noindex={!post}
>
	{
		post && (
			<script slot="head" type="application/ld+json" is:inline>
				{JSON.stringify({
					'@context': 'https://schema.org',
					'@type': 'BlogPosting',
					headline: post.title,
					description: post.excerpt,
					datePublished: post.publishedAt,
					dateModified: post.updatedAt ?? post.publishedAt,
					url: post.canonicalUrl ?? `https://maraolivaresnutricio.com${postPath}`,
					image: post.coverImage.src.startsWith('http')
						? post.coverImage.src
						: `https://maraolivaresnutricio.com${post.coverImage.src}`,
					publisher: {
						'@type': 'Organization',
						name: 'Mara Olivares Nutrició',
					},
				})}
			</script>
		)
	}

	{
		post ? (
			<section class="section">
				<div class="container article-layout">
					<article>
						<header class="article-header">
							<a class="button button--text article-back" href="/blog">← Volver al blog</a>
							<h1>{post.title}</h1>
							<BlogMeta publishedAt={post.publishedAt} category={post.category} tags={post.tags} />
							<img
								src={post.coverImage.src}
								alt={post.coverImage.alt}
								width="661"
								height="368"
								loading="lazy"
								decoding="async"
							/>
						</header>

						<div class="article-content">
							<PortableText value={post.content} />
						</div>

						<footer class="article-footer">
							<p>Si quieres un plan adaptado a tu caso, puedo ayudarte en consulta.</p>
							<a class="button" href="/contacto">Solicitar valoración</a>
						</footer>
					</article>
				</div>
			</section>
		) : (
			<section class="section">
				<div class="container not-found">
					<h1>Artículo no encontrado</h1>
					<p>El contenido que buscas no está disponible o ya no está publicado.</p>
					<a class="button" href="/blog">Volver al blog</a>
				</div>
			</section>
		)
	}
</BaseLayout>
