---
import heroImage from "../../assets/hero.png";
---

<section class="home-hero section" id="inicio">
  <img
    src={heroImage.src}
    width={heroImage.width}
    height={heroImage.height}
    alt="Mara Olivares"
    class="home-hero__image"
    loading="eager"
    decoding="async"
  />

  <div class="container home-hero__grid">
    <div class="home-hero__intro">
      <h1>
        <span class="home-hero__title-line home-hero__title-line--top">
          <span class="home-hero__title-bold">Nutrición real</span>
          <span class="home-hero__title-regular home-hero__title-para"
            >para</span
          >
        </span>
        <span class="home-hero__title-line home-hero__title-line--bottom">
          <span class="home-hero__title-regular home-hero__title-una">una</span>
          <span class="home-hero__title-serif">vida mejor</span>
        </span>
      </h1>
    </div>
  </div>

  <div class="home-hero__subtitle-band">
    <div class="container">
      <p>
        Te acompaño a construir hábitos saludables que se adapten a ti, con
        ciencia, empatía y <strong>resultados duraderos.</strong>
      </p>
    </div>
  </div>

  <div class="container home-hero__actions">
    <a
      class="button home-hero__button home-hero__button--light"
      href="/servicios">Servicios</a
    >
    <a
      class="button home-hero__button home-hero__button--cream"
      href="/contacto">Agenda tu cita</a
    >
  </div>
</section>
