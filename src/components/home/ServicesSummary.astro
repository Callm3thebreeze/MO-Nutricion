---
import BrandIcon from "../ui/BrandIcon.astro";

const services: Array<{
  title: string;
  description: string;
  icon:
    | "scale"
    | "stethoscope"
    | "microbiota"
    | "book"
    | "dumbbell"
    | "hormone";
}> = [
  {
    title: "Pérdida de grasa",
    description:
      "Planes personalizados para una composición corporal más saludable.",
    icon: "scale",
  },
  {
    title: "Nutrición clínica",
    description: "Acompañamiento en condiciones de salud específicas.",
    icon: "stethoscope",
  },
  {
    title: "Salud digestiva",
    description: "Mejoramos tu digestión y bienestar intestinal.",
    icon: "microbiota",
  },
  {
    title: "Educación nutricional",
    description: "Aprende a comer mejor y tomar decisiones conscientes.",
    icon: "book",
  },
  {
    title: "Nutrición deportiva",
    description: "Optimiza tu rendimiento y recuperación.",
    icon: "dumbbell",
  },
  {
    title: "Salud hormonal",
    description: "Apoyo nutricional en etapas clave de tu vida hormonal.",
    icon: "hormone",
  },
];
---

<section class="section services-summary" id="servicios">
  <div class="container">
    <h2>¿Cómo te puedo ayudar?</h2>
    <div class="wave-divider" aria-hidden="true"></div>
    <div class="card-grid card-grid--services">
      {
        services.map((service) => (
          <article class="service-card">
            <div class="service-card__icon-wrap" aria-hidden="true">
              <BrandIcon name={service.icon} />
            </div>
            <h3>{service.title}</h3>
            <p>{service.description}</p>
            <a
              class="service-card__link"
              href="/contacto"
              aria-label={`Quiero saber más sobre ${service.title}`}
            >
              <span aria-hidden="true">→</span>
            </a>
          </article>
        ))
      }
    </div>
  </div>
</section>
