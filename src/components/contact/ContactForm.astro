---
import BrandIcon from "../ui/BrandIcon.astro";
import WaveDivider from "../ui/WaveDivider.astro";
import contactFormScript from "../../scripts/contact-form.ts?url";

const contactHighlights = [
  {
    title: "Primera valoración clara",
    description:
      "Analizamos tu caso y definimos prioridades desde la primera sesión.",
    icon: "clipboard" as const,
  },
  {
    title: "Plan adaptado a ti",
    description:
      "Pautas personalizadas para tu rutina, tus gustos y tus objetivos.",
    icon: "check" as const,
  },
  {
    title: "Acompañamiento cercano",
    description:
      "Seguimiento profesional para sostener tus cambios en el tiempo.",
    icon: "heart" as const,
  },
];
---

<section class="section contact-section">
  <div class="container contact-wrapper">
    <header class="contact-intro scroll-reveal">
      <h1>Cuéntame tu caso y diseñamos tu ruta de mejora</h1>
      <WaveDivider />
      <p>
        Si quieres que valoremos tu caso, completa este formulario. En esta
        versión el envío es simulado para validar la experiencia de usuario.
      </p>
    </header>

    <div class="contact-content">
      <ul
        class="contact-highlights scroll-reveal"
        style="--home-reveal-delay: 50ms"
        aria-label="Beneficios del acompañamiento"
      >
        {
          contactHighlights.map((highlight) => (
            <li class="contact-highlights__item">
              <BrandIcon
                name={highlight.icon}
                class="contact-highlights__watermark"
              />
              <span class="contact-highlights__icon">
                <BrandIcon name={highlight.icon} />
              </span>
              <div>
                <h2>{highlight.title}</h2>
                <p>{highlight.description}</p>
              </div>
            </li>
          ))
        }
      </ul>

      <form
        class="contact-form scroll-reveal"
        style="--home-reveal-delay: 90ms"
        data-contact-form
        novalidate
      >
      <div class="form-row">
        <label for="nombre">Nombre y apellidos</label>
        <input
          id="nombre"
          name="nombre"
          type="text"
          autocomplete="name"
          minlength="2"
          required
          aria-describedby="error-nombre"
        />
        <p
          id="error-nombre"
          class="field-error"
          data-error-for="nombre"
          aria-live="assertive"
          aria-atomic="true"
        >
        </p>
      </div>

      <div class="form-row">
        <label for="email">Correo electrónico</label>
        <input
          id="email"
          name="email"
          type="email"
          autocomplete="email"
          required
          aria-describedby="error-email"
        />
        <p
          id="error-email"
          class="field-error"
          data-error-for="email"
          aria-live="assertive"
          aria-atomic="true"
        >
        </p>
      </div>

      <div class="form-row">
        <label for="motivo">Motivo de consulta</label>
        <select
          id="motivo"
          name="motivo"
          required
          aria-describedby="error-motivo"
        >
          <option value="">Selecciona una opción</option>
          <option value="digestivo">Síntomas digestivos</option>
          <option value="microbiota">Microbiota</option>
          <option value="hormonal">Salud hormonal</option>
          <option value="habitos">Hábitos y educación nutricional</option>
        </select>
        <p
          id="error-motivo"
          class="field-error"
          data-error-for="motivo"
          aria-live="assertive"
          aria-atomic="true"
        >
        </p>
      </div>

      <div class="form-row">
        <label for="mensaje">Mensaje</label>
        <textarea
          id="mensaje"
          name="mensaje"
          rows="5"
          minlength="20"
          required
          aria-describedby="error-mensaje"></textarea>
        <p
          id="error-mensaje"
          class="field-error"
          data-error-for="mensaje"
          aria-live="assertive"
          aria-atomic="true"
        >
        </p>
      </div>

      <div class="form-row form-row--checkbox">
        <input
          id="consentimiento"
          name="consentimiento"
          type="checkbox"
          required
          aria-describedby="error-consentimiento"
        />
        <label for="consentimiento">
          Acepto el tratamiento de mis datos para recibir respuesta a mi
          consulta.
        </label>
      </div>
      <p
        id="error-consentimiento"
        class="field-error"
        data-error-for="consentimiento"
        aria-live="assertive"
        aria-atomic="true"
      >
      </p>

      <button type="submit" class="button">Enviar solicitud</button>
      <p
        class="form-status"
        id="contacto-status"
        data-form-status
        role="status"
        aria-live="polite"
        aria-atomic="true"
      >
      </p>
      </form>
    </div>
  </div>
</section>

<script is:inline type="module" src={contactFormScript}></script>
