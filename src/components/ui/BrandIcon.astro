---
import microbiotaSvgRaw from "../../assets/microbiota.svg?raw";
import stethoscopeSvgRaw from "../../assets/estetoscopio.svg?raw";

type IconName =
  | "clipboard"
  | "heart"
  | "microbiota"
  | "leaf"
  | "scale"
  | "stethoscope"
  | "book"
  | "dumbbell"
  | "hormone"
  | "user"
  | "target"
  | "calendar"
  | "chat"
  | "check"
  | "at"
  | "mail"
  | "phone"
  | "location";

interface Props {
  name: IconName;
  title?: string;
  decorative?: boolean;
  class?: string;
}

const {
  name,
  title,
  decorative = true,
  class: className = "",
} = Astro.props as Props;

const iconClass = `brand-icon ${className}`.trim();

const withBaseSvgAttributes = (svg: string): string =>
  svg.replace(/<svg\b[^>]*>/, (match) => {
    const classAttr = `class="${iconClass}"`;
    const ariaAttr = decorative
      ? 'aria-hidden="true"'
      : `role="img" aria-label="${title ?? name}"`;

    if (match.includes("class=")) {
      return match
        .replace(/class="([^"]*)"/, `class="$1 ${iconClass}"`)
        .replace("<svg", `<svg ${ariaAttr}`);
    }

    return match.replace("<svg", `<svg ${classAttr} ${ariaAttr}`);
  });

const externalSvg =
  name === "microbiota"
    ? withBaseSvgAttributes(microbiotaSvgRaw)
    : name === "stethoscope"
      ? withBaseSvgAttributes(stethoscopeSvgRaw)
      : null;
---

{
  externalSvg ? (
    <Fragment set:html={externalSvg} />
  ) : (
    <svg
      class={iconClass}
      viewBox="0 0 48 48"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
      stroke="currentColor"
      stroke-width="2.35"
      stroke-linecap="round"
      stroke-linejoin="round"
      role={decorative ? undefined : "img"}
      aria-hidden={decorative ? "true" : undefined}
    >
      {!decorative && <title>{title ?? name}</title>}

      {name === "clipboard" && (
        <>
          <rect x="10" y="10" width="26" height="30" rx="5" />
          <rect x="17" y="6" width="12" height="8" rx="3" fill="#fff" />
          <path d="M17 22h12" />
          <path d="M17 28h8" />
          <circle cx="31.5" cy="31.5" r="5.5" fill="#fff" />
          <path d="m29.5 31.5 1.6 1.6 3.3-3.3" />
        </>
      )}

      {name === "heart" && (
        <path d="M24 39s-12.5-7.6-12.5-16.8c0-4.9 3.8-8.2 8.1-8.2 2.5 0 4.2 1 4.4 2.8.2-1.8 1.9-2.8 4.4-2.8 4.3 0 8.1 3.3 8.1 8.2C36.5 31.4 24 39 24 39Z" />
      )}

      {name === "leaf" && (
        <>
          <path d="M24 39V23" />
          <path d="M24 24c0-8 6-13 14-13-1 8-6 14-14 14" fill="#fff" />
          <path d="M24 27c0-8-6-13-14-13 1 8 6 14 14 14" fill="#fff" />
        </>
      )}

      {name === "scale" && (
        <>
          <rect x="9" y="10" width="30" height="30" rx="6" />
          <circle cx="24" cy="18" r="4.8" fill="#fff" />
          <path d="M24 18V15" />
        </>
      )}

      {name === "book" && (
        <>
          <path d="M9 14c4.1-2 8.1-2 12.2 0l2.8 1.7 2.8-1.7c4.1-2 8.1-2 12.2 0v22.5c-4.1-2-8.1-2-12.2 0l-2.8 1.7-2.8-1.7c-4.1-2-8.1-2-12.2 0V14Z" />
          <path d="M24 15.7v24" />
          <path d="M13.2 18.1v13.6" />
          <path d="M34.8 18.1v13.6" />
        </>
      )}

      {name === "dumbbell" && (
        <>
          <rect x="6" y="18" width="5" height="12" rx="1.5" fill="#fff" />
          <rect x="37" y="18" width="5" height="12" rx="1.5" fill="#fff" />
          <rect x="12.5" y="15" width="4.5" height="18" rx="1.5" />
          <rect x="31" y="15" width="4.5" height="18" rx="1.5" />
          <path d="M17 24h14" />
        </>
      )}

      {name === "hormone" && (
        <>
          <path d="M24 12v12m0 0-10 8m10-8 10 8" />
          <circle cx="24" cy="24" r="4.5" fill="#fff" />
          <circle cx="24" cy="12" r="4.5" fill="#fff" />
          <circle cx="14" cy="32" r="4.5" fill="#fff" />
          <circle cx="34" cy="32" r="4.5" fill="#fff" />
        </>
      )}

      {name === "user" && (
        <>
          <circle cx="24" cy="14" r="6" fill="#fff" />
          <path d="M11 38a13 13 0 0 1 26 0v2H11Z" fill="#fff" />
        </>
      )}

      {name === "target" && (
        <>
          <circle cx="24" cy="24" r="14" />
          <circle cx="24" cy="24" r="8" />
          <circle cx="24" cy="24" r="2.5" fill="currentColor" />
          <path d="m24 24 11-11" />
          <path d="M30 13h5v5" />
        </>
      )}

      {name === "calendar" && (
        <>
          <rect x="8" y="10" width="32" height="30" rx="6" />
          <path d="M8 18h32" />
          <path d="M15 8v6" />
          <path d="M33 8v6" />
          <path d="M15 25h6" />
          <path d="M15 31h6" />
          <path d="M27 25h6" />
          <path d="M27 31h6" />
        </>
      )}

      {name === "chat" && (
        <>
          <path d="M10 12h28a6 6 0 0 1 6 6v10a6 6 0 0 1-6 6H22l-8 7v-7h-4a6 6 0 0 1-6-6V18a6 6 0 0 1 6-6Z" />
          <circle cx="18" cy="23" r="1.4" fill="currentColor" />
          <circle cx="24" cy="23" r="1.4" fill="currentColor" />
          <circle cx="30" cy="23" r="1.4" fill="currentColor" />
        </>
      )}

      {name === "check" && (
        <>
          <circle cx="24" cy="24" r="15" fill="#fff" />
          <path d="m17 24 5 5 9-9" />
        </>
      )}

      {name === "at" && (
        <>
          <circle cx="24" cy="24" r="14" />
          <circle cx="24" cy="24" r="5" fill="#fff" />
          <path d="M29 29.5c-1.1 1-2.7 1.5-4.6 1.5-4.3 0-7.4-2.9-7.4-7.2S20.1 17 24.2 17c3.6 0 6.4 2.3 6.4 5.7v3.6c0 1 .7 1.7 1.6 1.7.8 0 1.4-.4 1.8-1.2" />
        </>
      )}

      {name === "mail" && (
        <>
          <rect x="8" y="13" width="32" height="22" rx="4" fill="#fff" />
          <path d="m9.5 16.5 14.5 10 14.5-10" />
        </>
      )}

      {name === "phone" && (
        <>
          <path
            d="M16.2 9.8h5.1l1.8 7.2-2.8 2.2a26.5 26.5 0 0 0 8.5 8.5l2.2-2.8 7.2 1.8v5.1c0 1.5-1.2 2.7-2.7 2.7C21 34.5 13.5 27 13.5 17.2c0-1.5 1.2-2.7 2.7-2.7Z"
            fill="#fff"
          />
        </>
      )}

      {name === "location" && (
        <>
          <path
            d="M24 39s10-9.4 10-16a10 10 0 1 0-20 0c0 6.6 10 16 10 16Z"
            fill="#fff"
          />
          <circle cx="24" cy="23" r="3.3" />
        </>
      )}
    </svg>
  )
}
