---
type IconName =
  | "clipboard"
  | "heart"
  | "microbiota"
  | "leaf"
  | "scale"
  | "stethoscope"
  | "book"
  | "dumbbell"
  | "hormone"
  | "user"
  | "target"
  | "calendar"
  | "chat"
  | "check";

interface Props {
  name: IconName;
  title?: string;
  decorative?: boolean;
  class?: string;
}

const {
  name,
  title,
  decorative = true,
  class: className = "",
} = Astro.props as Props;
---

<svg
  class={`brand-icon ${className}`.trim()}
  viewBox="0 0 48 48"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  stroke="currentColor"
  stroke-width="2.35"
  stroke-linecap="round"
  stroke-linejoin="round"
  role={decorative ? undefined : "img"}
  aria-hidden={decorative ? "true" : undefined}
>
  {!decorative && <title>{title ?? name}</title>}

  {
    name === "clipboard" && (
      <>
        <rect x="10" y="10" width="26" height="30" rx="5" />
        <rect
          x="17"
          y="6"
          width="12"
          height="8"
          rx="3"
          fill="var(--color-brand-cream)"
        />
        <path d="M17 22h12" />
        <path d="M17 28h8" />
        <circle cx="31.5" cy="31.5" r="5.5" fill="var(--color-brand-mint)" />
        <path d="m29.5 31.5 1.6 1.6 3.3-3.3" />
      </>
    )
  }

  {
    name === "heart" && (
      <path d="M24 39s-12.5-7.6-12.5-16.8c0-4.9 3.8-8.2 8.1-8.2 2.5 0 4.2 1 4.4 2.8.2-1.8 1.9-2.8 4.4-2.8 4.3 0 8.1 3.3 8.1 8.2C36.5 31.4 24 39 24 39Z" />
    )
  }

  {
    name === "microbiota" && (
      <>
        <path d="M14 12h8c2.8 0 5 2.2 5 5s-2.2 5-5 5h-6c-2.8 0-5 2.2-5 5s2.2 5 5 5h14c3.3 0 6 2.7 6 6" />
        <path d="M34 12c1.7 0 3 1.3 3 3s-1.3 3-3 3h-7" />
        <path d="M23 22h10c2.8 0 5 2.2 5 5s-2.2 5-5 5h-4" />
        <path d="M17 32v4" />
      </>
    )
  }

  {
    name === "leaf" && (
      <>
        <path d="M24 39V23" />
        <path
          d="M24 24c0-8 6-13 14-13-1 8-6 14-14 14"
          fill="var(--color-brand-mint)"
        />
        <path
          d="M24 27c0-8-6-13-14-13 1 8 6 14 14 14"
          fill="var(--color-brand-lilac)"
        />
      </>
    )
  }

  {
    name === "scale" && (
      <>
        <rect x="9" y="10" width="30" height="30" rx="6" />
        <circle cx="24" cy="18" r="4.8" fill="var(--color-brand-lilac)" />
        <path d="M24 18V15" />
      </>
    )
  }

  {
    name === "stethoscope" && (
      <>
        <path d="M15 12v9a6 6 0 0 0 12 0v-9" />
        <path d="M12 12h6" />
        <path d="M27 12h6" />
        <path d="M21 27v5a6 6 0 0 0 6 6h2a5 5 0 1 0 0-10h-1" />
        <circle cx="35" cy="33" r="2.5" fill="var(--color-brand-cream)" />
      </>
    )
  }

  {
    name === "book" && (
      <>
        <path d="M8 14a6 6 0 0 1 6-6h10v28H14a6 6 0 0 0-6 6V14Z" />
        <path d="M40 14a6 6 0 0 0-6-6H24v28h10a6 6 0 0 1 6 6V14Z" />
      </>
    )
  }

  {
    name === "dumbbell" && (
      <>
        <rect
          x="6"
          y="18"
          width="5"
          height="12"
          rx="1.5"
          fill="var(--color-brand-lilac)"
        />
        <rect
          x="37"
          y="18"
          width="5"
          height="12"
          rx="1.5"
          fill="var(--color-brand-lilac)"
        />
        <rect x="12.5" y="15" width="4.5" height="18" rx="1.5" />
        <rect x="31" y="15" width="4.5" height="18" rx="1.5" />
        <path d="M17 24h14" />
      </>
    )
  }

  {
    name === "hormone" && (
      <>
        <circle cx="24" cy="18" r="9" />
        <path d="M24 27v13" />
        <path d="M19 35h10" />
      </>
    )
  }

  {
    name === "user" && (
      <>
        <circle cx="24" cy="14" r="6" fill="var(--color-brand-lilac)" />
        <path
          d="M11 38a13 13 0 0 1 26 0v2H11Z"
          fill="var(--color-brand-cream)"
        />
      </>
    )
  }

  {
    name === "target" && (
      <>
        <circle cx="24" cy="24" r="14" />
        <circle cx="24" cy="24" r="8" />
        <circle cx="24" cy="24" r="2.5" fill="currentColor" />
        <path d="m24 24 11-11" />
        <path d="M30 13h5v5" />
      </>
    )
  }

  {
    name === "calendar" && (
      <>
        <rect x="8" y="10" width="32" height="30" rx="6" />
        <path d="M8 18h32" />
        <path d="M15 8v6" />
        <path d="M33 8v6" />
        <path d="M15 25h6" />
        <path d="M15 31h6" />
        <path d="M27 25h6" />
        <path d="M27 31h6" />
      </>
    )
  }

  {
    name === "chat" && (
      <>
        <path d="M10 12h28a6 6 0 0 1 6 6v10a6 6 0 0 1-6 6H22l-8 7v-7h-4a6 6 0 0 1-6-6V18a6 6 0 0 1 6-6Z" />
        <circle cx="18" cy="23" r="1.4" fill="currentColor" />
        <circle cx="24" cy="23" r="1.4" fill="currentColor" />
        <circle cx="30" cy="23" r="1.4" fill="currentColor" />
      </>
    )
  }

  {
    name === "check" && (
      <>
        <circle cx="24" cy="24" r="15" fill="var(--color-brand-mint)" />
        <path d="m17 24 5 5 9-9" />
      </>
    )
  }
</svg>
