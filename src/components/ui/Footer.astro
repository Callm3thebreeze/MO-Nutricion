---
const socialLinks = [
  {
    href: "https://www.instagram.com/maraolivares.nutricion/",
    label: "Instagram",
    short: "IG",
  },
  {
    href: "https://www.facebook.com/",
    label: "Facebook",
    short: "FB",
  },
  {
    href: "https://wa.me/34600135465",
    label: "WhatsApp",
    short: "WA",
  },
];
---

<footer class="site-footer">
  <div class="container site-footer__inner">
    <div class="site-footer__brand">
      <img
        src="/assets/logo/main-logo.png"
        width="661"
        height="368"
        alt="Logotipo de Mara Olivares Nutrició"
        loading="lazy"
        decoding="async"
      />
      <p>Nutrición real, hábitos que suman bienestar.</p>
      <ul class="site-footer__social" aria-label="Redes sociales">
        {
          socialLinks.map((link) => (
            <li>
              <a
                href={link.href}
                aria-label={link.label}
                target="_blank"
                rel="noopener noreferrer"
              >
                {link.short}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <div class="site-footer__column">
      <h2>Servicios</h2>
      <ul class="site-footer__list">
        <li>Consulta nutricional</li>
        <li>Nutrición clínica</li>
        <li>Salud digestiva</li>
        <li>Nutrición deportiva</li>
        <li>Salud hormonal</li>
      </ul>
    </div>

    <div class="site-footer__column">
      <h2>Contacto</h2>
      <ul class="site-footer__contact">
        <li>
          <a
            href="https://www.instagram.com/maraolivares.nutricion/"
            target="_blank"
            rel="noopener noreferrer"
          >
            @maraolivares.nutricion
          </a>
        </li>
        <li>
          <a href="mailto:hola@maraolivares.com">hola@maraolivares.com</a>
        </li>
        <li><a href="tel:+34600135465">+34 600 135 465</a></li>
        <li>Consultas presenciales y online</li>
      </ul>
      <div class="site-footer__newsletter">
        <p>Recursos y consejos para tu bienestar</p>
      </div>
    </div>
  </div>

  <div class="container site-footer__legal">
    <p>Aviso legal y política de privacidad disponibles próximamente.</p>
    <p>© {new Date().getFullYear()} Mara Olivares Nutrició</p>
  </div>
</footer>
