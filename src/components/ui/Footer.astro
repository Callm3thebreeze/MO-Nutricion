---
import altLogo from "../../assets/logo/alt-logo.png";
import {
  EnvelopeIcon,
  PhoneIcon,
  MapPinIcon,
} from "@heroicons/react/24/outline";
---

<footer class="site-footer">
  <div class="container site-footer__inner">
    <div class="site-footer__brand">
      <img
        src={altLogo.src}
        width={altLogo.width}
        height={altLogo.height}
        alt="Logotipo de Mara Olivares Nutrició"
        loading="lazy"
        decoding="async"
      />
      <p>Nutrición real, hábitos que suman bienestar.</p>
    </div>

    <div class="site-footer__column">
      <h2>Servicios</h2>
      <ul class="site-footer__list">
        <li>Consulta nutricional</li>
        <li>Nutrición clínica</li>
        <li>Salud digestiva</li>
        <li>Nutrición deportiva</li>
        <li>Salud hormonal</li>
      </ul>
    </div>

    <div class="site-footer__column">
      <h2>Contacto</h2>
      <ul class="site-footer__contact">
        <li>
          <EnvelopeIcon
            className="site-footer__contact-icon"
            aria-hidden="true"
          />
          <a href="mailto:hola@maraolivares.com">hola@maraolivares.com</a>
        </li>
        <li>
          <PhoneIcon className="site-footer__contact-icon" aria-hidden="true" />
          <a href="tel:+34600135465">+34 600 135 465</a>
        </li>
        <li>
          <MapPinIcon
            className="site-footer__contact-icon"
            aria-hidden="true"
          />
          <span>Consultas presenciales y online</span>
        </li>
      </ul>
    </div>
  </div>

  <div class="container site-footer__legal">
    <p>Aviso legal y política de privacidad disponibles próximamente.</p>
    <p>© {new Date().getFullYear()} Mara Olivares Nutrició</p>
  </div>
</footer>
